{
  "version": 1,
  "brand": "{{ brand_name }}",
  "is_default": true,
  "canvas": {
    "width": 1080,
    "height": 1350,
    "aspect_label": "4:5 LinkedIn carousel"
  },
  "fonts": {
    "display": { "family": "Geist", "weight": 900 },
    "body":    { "family": "Geist", "weight": 400 },
    "bold":    { "family": "Geist", "weight": 700 },
    "mono":    { "family": "JetBrains Mono", "weight": 500 }
  },
  "type_scale": {
    "display":  { "size": 108, "line_height": 1.0,  "letter_spacing": "-0.045em" },
    "h1":       { "size": 72,  "line_height": 1.05, "letter_spacing": "-0.035em" },
    "h2":       { "size": 56,  "line_height": 1.1,  "letter_spacing": "-0.02em"  },
    "subtitle": { "size": 40,  "line_height": 1.3,  "letter_spacing": "-0.01em"  },
    "body":     { "size": 28,  "line_height": 1.4,  "letter_spacing": "0"        },
    "caption":  { "size": 22,  "line_height": 1.3,  "letter_spacing": "0.05em"   }
  },
  "colors": {
    "primary":       "#0a0a0a",
    "secondary":     "#5a5854",
    "accent":        "#e25a45",
    "bg_light":      "#f2f0eb",
    "bg_dark":       "#1d1c1c",
    "text_on_dark":  "#f2f0eb",
    "text_on_light": "#0a0a0a",
    "text_muted":    "#6c6a64",
    "border_subtle": "#d8d3c8"
  },
  "spacing": {
    "canvas_padding": 80,
    "block_padding_v": 50,
    "block_padding_h": 40,
    "scale": {
      "2xs": 4, "xs": 8, "sm": 12, "md": 16, "lg": 24,
      "xl": 32, "2xl": 48, "3xl": 64, "4xl": 96, "5xl": 128
    }
  },
  "locked_fields": [],
  "_note": "Default neutral identity. Copy into brand_context/visual-identity/ when the user has no brand to start from. Refine incrementally as the user adds references."
}
