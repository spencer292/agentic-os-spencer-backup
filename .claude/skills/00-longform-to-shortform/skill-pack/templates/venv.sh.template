#!/bin/bash
# Cross-platform venv activation helper
# Source this script to activate the video pipeline's Python venv.
# Usage: source tools/venv.sh

TOOLS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$TOOLS_DIR/.venv"

if [ ! -d "$VENV_DIR" ]; then
  echo "ERROR: Virtual environment not found at $VENV_DIR"
  echo "Run: ./setup.sh"
  return 1 2>/dev/null || exit 1
fi

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*) source "$VENV_DIR/Scripts/activate" ;;
  *)                     source "$VENV_DIR/bin/activate" ;;
esac
