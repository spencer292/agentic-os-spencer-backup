#!/bin/bash
# Setup script for Video Pipeline
# Creates a Python venv and installs all dependencies (clip extractor + WhisperX)

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$SCRIPT_DIR/tools/.venv"

# Detect platform
OS="$(uname -s)"
case "$OS" in
  Darwin*)  PLATFORM="macos" ;;
  Linux*)   PLATFORM="linux" ;;
  MINGW*|MSYS*|CYGWIN*) PLATFORM="windows" ;;
  *)        PLATFORM="unknown" ;;
esac

echo "==> Setting up Video Pipeline ($PLATFORM)"

# Find a suitable Python (3.10-3.13)
PYTHON=""
if [ "$PLATFORM" = "macos" ]; then
    candidates=(/opt/homebrew/bin/python3.12 /opt/homebrew/bin/python3.13 /opt/homebrew/bin/python3.11 /opt/homebrew/bin/python3.10 python3.12 python3.13 python3.11 python3.10 python3)
elif [ "$PLATFORM" = "windows" ]; then
    candidates=(py python python3)
else
    candidates=(python3.12 python3.13 python3.11 python3.10 python3)
fi

for candidate in "${candidates[@]}"; do
    if [ "$PLATFORM" = "windows" ] && [ "$candidate" = "py" ]; then
        # On Windows, try py launcher with version flags
        for pyver in 3.12 3.13 3.11 3.10; do
            if py -"$pyver" --version &>/dev/null; then
                version=$(py -"$pyver" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+')
                major=$(echo "$version" | cut -d. -f1)
                minor=$(echo "$version" | cut -d. -f2)
                if [ "$major" -eq 3 ] && [ "$minor" -ge 10 ] && [ "$minor" -le 13 ]; then
                    PYTHON="py -$pyver"
                    echo "    Found Python: $PYTHON ($(py -"$pyver" --version))"
                    break 2
                fi
            fi
        done
        continue
    fi
    if command -v "$candidate" &>/dev/null; then
        version=$("$candidate" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+')
        major=$(echo "$version" | cut -d. -f1)
        minor=$(echo "$version" | cut -d. -f2)
        if [ "$major" -eq 3 ] && [ "$minor" -ge 10 ] && [ "$minor" -le 13 ]; then
            PYTHON="$candidate"
            echo "    Found Python: $PYTHON ($("$PYTHON" --version))"
            break
        fi
    fi
done

if [ -z "$PYTHON" ]; then
    echo "ERROR: Python 3.10-3.13 required but not found."
    echo ""
    if [ "$PLATFORM" = "macos" ]; then
        echo "On macOS Apple Silicon, install arm64 Python:"
        echo "  /opt/homebrew/bin/brew install python@3.12"
        echo ""
        echo "If you don't have arm64 Homebrew:"
        echo "  arch -arm64 /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
        echo "  /opt/homebrew/bin/brew install python@3.12"
    elif [ "$PLATFORM" = "windows" ]; then
        echo "Install Python 3.12:"
        echo "  winget install Python.Python.3.12"
        echo ""
        echo "Or download from https://www.python.org/downloads/"
    else
        echo "Install Python 3.12:"
        echo "  apt install python3.12    # Debian/Ubuntu"
        echo "  dnf install python3.12    # Fedora/RHEL"
    fi
    exit 1
fi

# Check architecture on macOS (PyTorch needs arm64)
if [ "$PLATFORM" = "macos" ] && [ "$(uname -m)" = "arm64" ]; then
    arch=$(file "$PYTHON" 2>/dev/null | grep -o 'arm64\|x86_64' | head -1)
    if [ "$arch" = "x86_64" ]; then
        echo "WARNING: Found x86_64 Python on arm64 Mac. PyTorch may not install correctly."
        echo "Install arm64 Python: /opt/homebrew/bin/brew install python@3.12"
        exit 1
    fi
fi

# Create venv
if [ -d "$VENV_DIR" ]; then
    echo "    Removing existing venv..."
    rm -rf "$VENV_DIR"
fi

echo "==> Creating virtual environment..."
$PYTHON -m venv "$VENV_DIR"

if [ "$PLATFORM" = "windows" ]; then
    source "$VENV_DIR/Scripts/activate"
else
    source "$VENV_DIR/bin/activate"
fi

echo "==> Upgrading pip..."
pip install --upgrade pip -q

echo "==> Installing dependencies..."
pip install -r "$SCRIPT_DIR/tools/clip_extractor/requirements.txt"

echo "==> Verifying key packages..."
python -c "import mediapipe, cv2, numpy, yaml, filterpy, rapidfuzz; print('    All packages OK')" || {
    echo "ERROR: Some packages failed to install. Check output above."
    exit 1
}

echo ""
echo "==> Verifying yt-dlp..."
if [ "$PLATFORM" = "windows" ]; then
    YT_DLP="$VENV_DIR/Scripts/yt-dlp.exe"
else
    YT_DLP="$VENV_DIR/bin/yt-dlp"
fi
if "$YT_DLP" --version &>/dev/null; then
    echo "    yt-dlp: $("$YT_DLP" --version)"
else
    echo "WARNING: yt-dlp not available"
fi

echo "==> Checking ffmpeg..."
if command -v ffmpeg &>/dev/null; then
    echo "    ffmpeg: $(ffmpeg -version 2>&1 | head -1)"
else
    if [ "$PLATFORM" = "macos" ]; then
        echo "WARNING: ffmpeg not found. Install: brew install ffmpeg"
    elif [ "$PLATFORM" = "windows" ]; then
        echo "WARNING: ffmpeg not found. Install: winget install Gyan.FFmpeg"
    else
        echo "WARNING: ffmpeg not found. Install: apt install ffmpeg"
    fi
fi

echo ""
echo "==> Setup complete!"
echo ""
echo "Activate the environment:"
if [ "$PLATFORM" = "windows" ]; then
    echo "  source tools/.venv/Scripts/activate"
else
    echo "  source tools/.venv/bin/activate"
fi
echo "  source tools/venv.sh   # cross-platform alternative"
echo ""
echo "Quick test:"
echo "  whisperx --help"
echo "  python -m clip_extractor --help"
