# Supabase PostgreSQL connection string (Transaction pooler, port 6543)
DATABASE_URI=postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Payload CMS secret (generate a random string)
PAYLOAD_SECRET=your-secret-here-change-this

# Vercel Blob Storage (auto-set by Vercel when you add Blob to the project)
# Only needed in production — local dev uses filesystem
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
