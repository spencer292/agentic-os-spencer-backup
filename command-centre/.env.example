# Optional: absolute path to the AgenticOS workspace root.
#
# The launcher auto-detects this when unset. Only set it if command-centre
# should read and write against a different checkout than the one it is running from.
#
# AGENTIC_OS_DIR=/absolute/path/to/agentic-os

# Optional: hosted team memory — Postgres + pgvector (Railway or VPS).
#
# When MEMORY_DATABASE_URL (or DATABASE_URL) is set, ALL memory commands
# (memory:migrate / memory:index / memory:search / memory:recall) run against
# hosted Postgres — the same schema local PGLite runs. Unset → local PGLite.
# Falls back to DATABASE_URL (Railway injects it). Never commit a real value.
#
# MEMORY_DATABASE_URL=postgres://user:password@host:5432/agentic_memory
# PGSSLMODE=        # disable | require | no-verify (default: on for remote, off for localhost)
#
# Optional: pin the storage engine. auto (default) = Postgres iff a connection
# string is set, else PGLite. `postgres` REQUIRES a URL (errors rather than
# silently using the local store); `pglite` forces local and ignores any URL.
# MEMORY_STORE_BACKEND=auto   # auto | pglite | postgres
