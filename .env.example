# API keys for Agentic OS skills
# This file is auto-created as .env by the installer — just fill in your keys below
# All keys are optional — skills work without them and tell you when one would help

# Firecrawl — web scraping, branding extraction (https://www.firecrawl.dev/app)
# Used by: firecrawl-scraper skill, mkt-brand-voice Auto-Scrape mode
# Free tier: 500 credits/month
FIRECRAWL_API_KEY=

# OpenAI — Reddit search via Responses API (https://platform.openai.com/api-keys)
# Used by: str-trending-research (Reddit threads with real engagement metrics)
# Pay-as-you-go pricing
OPENAI_API_KEY=

# xAI — X/Twitter search via xAI API (https://console.x.ai)
# Used by: str-trending-research (X posts with real likes, reposts, replies)
# Pay-as-you-go pricing
XAI_API_KEY=

# YouTube Data API v3 — channel listing,
# @handle resolution, video search
# Get a free key at https://console.cloud.google.com/ (10,000 units/day free tier)
# Used by: tool-youtube
YOUTUBE_API_KEY=

# Google Gemini — image generation via Gemini 3 Pro Image (https://ai.google.dev/)
# Used by: viz-nano-banana (image generation, infographics, visual content)
GEMINI_API_KEY=

# Google Workspace CLI (gws) — OAuth credentials for Drive, Gmail, Calendar, etc.
# Create a Desktop OAuth client at https://console.cloud.google.com/apis/credentials
# Used by: gws CLI (Google Workspace operations)
GOOGLE_WORKSPACE_CLI_CLIENT_ID=
GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=

# Telegram — bot token for Claude Code Channels plugin
# Create a bot via @BotFather on Telegram to get a token
# Used by: scripts/telegram.sh (Telegram channel launcher)
TELEGRAM_BOT_TOKEN=

# Telegram — comma-separated Telegram user IDs allowed to chat
# Get your ID from @userinfobot on Telegram
# Leave empty to allow all users (not recommended)
TELEGRAM_ALLOWED_USERS=

# memsearch - Milvus backend for semantic memory recall (Tier 1)
# macOS/Linux: leave empty — uses Milvus Lite locally (zero config)
# Windows: required — Milvus Lite has no Windows wheel on PyPI
#   Create a free cluster at https://cloud.zilliz.com, then paste URI + token below.
#   Free clusters are available in AWS eu-central-1 (Frankfurt)
#   and GCP us-west-1 (Oregon). Other regions may require a paid plan.
#   Run: powershell -File scripts\setup-memory.ps1 (opens browser automatically if empty)
ZILLIZ_URI=
ZILLIZ_TOKEN=

# Zernio — social media posting, scheduling, video upload, analytics
# Used by: tool-zernio-social, tool-publisher, tool-video-upload,
#          mkt-short-form-posting, mkt-content-analytics,
#          mkt-youtube-content-package, 00-longform-to-shortform (POST phase)
ZERNIO_API_KEY=

# Groq — fast Whisper transcription (https://console.groq.com)
# Used by: 00-longform-to-shortform, tool-transcription
# Without it: falls back to local WhisperX (slower)
GROQ_API_KEY=

# AssemblyAI — cloud transcription with word-level timestamps (https://www.assemblyai.com)
# Used by: 00-video-studio (talking-head captions + smart cut)
# Without it: falls back to Groq, then local WhisperX
ASSEMBLYAI_API_KEY=

# Apify — LinkedIn scraping (https://console.apify.com)
# Used by: tool-linkedin-scraper
APIFY_API_KEY=

# ScreenshotOne — rendered webpage screenshots (https://screenshotone.com)
# Used by: tool-web-screenshot (falls back to local Playwright without it)
SCREENSHOTONE_API_KEY=

# Unsplash / Pexels — stock photo search (both optional; Openverse needs no key)
# Used by: tool-image-search
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Descript API (podcast pipeline: auto-import, filler removal, export) - descript.com paid plan
DESCRIPT_API_TOKEN=

# Zoom Server-to-Server OAuth app (podcast ingest: recording download/backfill)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ElevenLabs (viz-remotion-video: AI voiceover for animated explainers)
ELEVENLABS_API_KEY=

# Google Ads (ops-google-ads: programmatic account management via the Google Ads API, no SDK)
# Developer token from the MCC API Center; OAuth Desktop client id+secret; mint the refresh
# token via .claude/skills/ops-google-ads/scripts/get-refresh-token.mjs. Customer IDs digits only.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Hosted team memory — Postgres + pgvector (Railway or VPS)
# Connection string for the hosted memory store. When set, ALL memory commands
# (memory:migrate / memory:index / memory:search / memory:recall) run against
# hosted Postgres instead of local PGLite — same schema either way. Falls back to
# DATABASE_URL, which Railway injects automatically. Never commit a real value.
# MEMORY_DATABASE_URL=postgres://user:password@host:5432/agentic_memory
# Optional SSL override: disable | require | no-verify
# (default: SSL on for remote hosts, off for localhost). Use `disable` for a
# Railway private/internal URL.
# PGSSLMODE=
# Optional: pin the storage engine. auto (default) = Postgres iff a connection
# string is set, else PGLite. `postgres` REQUIRES a URL (errors rather than
# silently using the local store); `pglite` forces local.
# MEMORY_STORE_BACKEND=auto   # auto | pglite | postgres

# Hosted memory API — ingest/search endpoints over the memory store
# Bearer token for the `npm run memory:api` server (POST /v1/memory/search and
# /v1/memory/ingest). REQUIRED to start the server — it never serves
# unauthenticated. Generate one with: openssl rand -hex 32
# MEMORY_API_TOKEN=
# Port for the API server. Falls back to PORT (Railway injects it), then 8787.
# MEMORY_API_PORT=8787

# SerpAPI — Google "People Also Ask" question harvesting (https://serpapi.com)
# Used by: str-question-harvester (FAQ gap discovery)
# Without it: falls back to manual/WebSearch PAA gathering
SERPAPI_API_KEY=

# n8n — workflow automation platform (https://n8n.io)
# Used by: future Got Moles automations (webhooks, lead alerts, scheduled workflows)
# Cloud: your instance URL looks like https://gotmoles.app.n8n.cloud
# API key: n8n Settings -> n8n API -> Create API key
N8N_BASE_URL=
N8N_API_KEY=

# Jobber — field service management (https://developer.getjobber.com)
# Used by: tool-jobber skill (clients, quotes, jobs, invoices via GraphQL API)
# Setup: create an app in the Developer Center, then run
#   node .claude/skills/tool-jobber/scripts/jobber-api.mjs auth
# JOBBER_REFRESH_TOKEN is written automatically by the auth flow.
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_REFRESH_TOKEN=
# Optional: pin the API version (YYYY-MM-DD, from the GraphiQL Playground)
JOBBER_GRAPHQL_VERSION=

# OptimoRoute — route optimization (https://optimoroute.com)
# Used by: tool-optimoroute skill (orders, route planning, completion tracking)
# Key: OptimoRoute app -> Administration -> Settings -> WS API
OPTIMOROUTE_API_KEY=
